# Sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=contacto@tudominio.com

# Google AdSense
# Etiqueta: <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXX" crossorigin="anonymous"></script>
NEXT_PUBLIC_ADS_ENABLED=true
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# IDs de unidad (data-ad-slot) — uno por cada bloque en el sitio
NEXT_PUBLIC_ADS_SLOT_HOME_TOP=
NEXT_PUBLIC_ADS_SLOT_HOME_BOTTOM=
NEXT_PUBLIC_ADS_SLOT_EXPLORE_TOP=
NEXT_PUBLIC_ADS_SLOT_EXPLORE_MID=
NEXT_PUBLIC_ADS_SLOT_ANIME_TOP=
NEXT_PUBLIC_ADS_SLOT_CALENDAR=
NEXT_PUBLIC_ADS_SLOT_MANGA=
NEXT_PUBLIC_ADS_SLOT_TECH=
NEXT_PUBLIC_ADS_SLOT_COLLECT=

# Mercado Libre Afiliados — SIN esto NO se muestran productos/tienda en el sitio
MERCADOLIBRE_AFFILIATE_ID=

# Streaming
CRUNCHYROLL_AFFILIATE_URL=https://www.crunchyroll.com

# Cron del agente de reseñas (POST /api/cron/generate-reviews)
CRON_SECRET=

# Upstash Redis — recomendado en producción (rate limiting)
# REQUIRE_RATE_LIMIT=true bloquea mutaciones si Redis no está configurado
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REQUIRE_RATE_LIMIT=

# Supabase — Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Solo servidor (NUNCA en el cliente). Tab Secret keys → sb_secret_...
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy (opcional): service_role JWT eyJ...
# SUPABASE_SERVICE_ROLE_KEY=

# IA curación editorial (opcional — sin esto usa criterio local)
REPLICATE_API_TOKEN=
REPLICATE_MODEL=meta/meta-llama-3-8b-instruct
