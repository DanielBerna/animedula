# Sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=contacto@tudominio.com

# Google AdSense
# Etiqueta: <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXX" crossorigin="anonymous"></script>
NEXT_PUBLIC_ADS_ENABLED=true
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# IDs de unidad (data-ad-slot) — uno por cada bloque en el sitio
NEXT_PUBLIC_ADS_SLOT_HOME_TOP=
NEXT_PUBLIC_ADS_SLOT_HOME_BOTTOM=
NEXT_PUBLIC_ADS_SLOT_EXPLORE_TOP=
NEXT_PUBLIC_ADS_SLOT_EXPLORE_MID=
NEXT_PUBLIC_ADS_SLOT_ANIME_TOP=
NEXT_PUBLIC_ADS_SLOT_CALENDAR=
NEXT_PUBLIC_ADS_SLOT_MANGA=
NEXT_PUBLIC_ADS_SLOT_TECH=
NEXT_PUBLIC_ADS_SLOT_COLLECT=

# Mercado Libre Afiliados — SIN esto NO se muestran productos/tienda en el sitio
MERCADOLIBRE_AFFILIATE_ID=

# Streaming
CRUNCHYROLL_AFFILIATE_URL=https://www.crunchyroll.com

# RAWG — catálogo amplio de videojuegos para el buscador del perfil (gratis: https://rawg.io/apidocs)
# Sin esta clave el buscador solo encuentra juegos free-to-play.
RAWG_API_KEY=

# Cron del agente de reseñas (POST /api/cron/generate-reviews)
CRON_SECRET=

# Upstash Redis — recomendado en producción (rate limiting)
# REQUIRE_RATE_LIMIT=true bloquea mutaciones si Redis no está configurado
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REQUIRE_RATE_LIMIT=

# Supabase — Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Solo servidor (NUNCA en el cliente). Tab Secret keys → sb_secret_...
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy (opcional): service_role JWT eyJ...
# SUPABASE_SERVICE_ROLE_KEY=

# IA curación editorial (opcional — sin esto usa criterio local)
REPLICATE_API_TOKEN=
REPLICATE_MODEL=meta/meta-llama-3-8b-instruct

# IA diseño de premios (opcional — usa el mismo REPLICATE_API_TOKEN de arriba)
# Sin token el botón "Generar con IA" no aparece y se sube todo manual (costo $0).
# texto → imagen (barato, ~$0.003/img):
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell
# boceto → imagen (image-to-image):
REPLICATE_IMG2IMG_MODEL=black-forest-labs/flux-dev
# quitar fondo (PNG transparente) — opcional, otro modelo (~$0.005/img):
REPLICATE_REMOVEBG_MODEL=851-labs/background-remover

# ── Sección "Ver anime" (/ver) — Opción B: espejos propios + agregadores de respaldo ──
# Prioridad: doblaje latino desde Supabase (schema v21). Externos solo sub/dub inglés.
#
# 1) Ejecuta supabase/schema-v21-watch-mirrors.sql
# 2) Configura espejos en /admin/espejos (HLS, MP4 o iframe por capítulo)
# 3) Agregadores iframe como fallback si no hay espejo o MAL no mapea:
#
# Placeholders: {malId} {anilistId} {ep} {type}   — type = sub|dub (no hay lat en externos)
# "anilistTemplate" opcional si MAL falla en ese proveedor.
NEXT_PUBLIC_ANIME_EMBED_PROVIDERS=[{"id":"megaplay","name":"MegaPlay","template":"https://megaplay.buzz/stream/mal/{malId}/{ep}/{type}","anilistTemplate":"https://megaplay.buzz/stream/anilist/{anilistId}/{ep}/{type}","dub":true},{"id":"vidlink","name":"Vidlink","template":"https://vidlink.pro/anime/{malId}/{ep}/{type}?fallback=true","dub":true},{"id":"ninja","name":"NinjaStream","template":"https://ninjasheild.stream/map/animemal/{malId}/{ep}/{type}","dub":true},{"id":"animeplay","name":"AnimePlay","template":"https://animeplay.cfd/stream/mal/{malId}/{ep}/{type}","dub":true}]
#
# Guía de costos y arquitectura: deploy/watch/README.md
#
# Legacy (no usar — DMCA 451 en GitHub):
# ANIWATCH_API_URL=
# CONSUMET_API_URL=
# CONSUMET_ANIME_PROVIDER=zoro

# Feed JSON para sincronizar espejos automáticamente (opcional).
# El cron POST /api/cron/sync-watch-mirrors descarga este JSON e importa.
# Puede ser GitHub raw, Supabase Storage público, R2, etc.
# WATCH_MIRROR_FEED_URL=https://raw.githubusercontent.com/tu-org/tu-repo/main/watch-feed.json
